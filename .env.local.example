# Copy this file to .env.local and fill in values.
# .env.local is gitignored and never committed.

# ── Content source ────────────────────────────────────────────────────────────
# Set this to use a GitHub repo as the content source instead of the local
# ./content/ directory. Format: "owner/repo"
# Leave unset during local development to use ./content/ directly.
GITHUB_REPO=your-username/your-blog-content

# Branch to read from (defaults to "main" if unset)
# GITHUB_BRANCH=main

# GitHub personal access token — required for private repos.
# Generate at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Scopes needed: Contents (read-only) for the content repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
